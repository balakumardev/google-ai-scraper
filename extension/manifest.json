{
  "manifest_version": 3,
  "name": "Google AI Overview Scraper",
  "version": "2.6",
  "description": "Extracts Google AI Overviews as structured markdown via a local MCP server",
  "permissions": ["tabs", "scripting", "alarms", "storage"],
  "host_permissions": [
    "https://www.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://[::1]/*",
    "https://localhost/*",
    "https://127.0.0.1/*",
    "https://[::1]/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Google AI Scraper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["lib/turndown.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
