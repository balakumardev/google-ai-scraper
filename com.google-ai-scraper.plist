<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.google-ai-scraper</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/balakumar/personal/google-ai-scraper/server/start-services.sh</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/balakumar/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
